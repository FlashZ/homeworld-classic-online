PRODUCT=homeworld
SHARED_EDGE=0
EDGE_DEFAULT_PRODUCT=homeworld
PORT_BIND_IP=0.0.0.0
PUBLIC_HOST=207.211.142.136
BACKEND_PORT=9100
CATACLYSM_BACKEND_PORT=9101
LOG_LEVEL=INFO
BACKEND_SHARED_SECRET=change-me-backend-secret
BACKEND_RPC_TIMEOUT=5
GATEWAY_PORT=15101
ROUTING_PORT=15100
ROUTING_MAX_PORT=15120
FIREWALL_PORT=2021
ADMIN_PORT=8080
ADMIN_TOKEN=change-me-dashboard-token
STATS_TOKEN=change-me-stats-token
# Reverse-proxy / forward-auth login (optional). Put a proxy that authenticates
# users in front of the admin port (Tailscale, Cloudflare Access, Authelia,
# oauth2-proxy, Authentik, ...) and have it inject the username header below.
# Leave ADMIN_FORWARD_USER_HEADER empty to disable and keep token-only auth.
# The proxy must also send ADMIN_FORWARD_SECRET in ADMIN_FORWARD_SECRET_HEADER so
# identity headers cannot be spoofed if the admin port is ever reachable directly.
ADMIN_FORWARD_USER_HEADER=
ADMIN_FORWARD_SECRET=
ADMIN_FORWARD_SECRET_HEADER=x-admin-proxy-secret
ADMIN_FORWARD_GROUPS_HEADER=
# Comma-separated group allowlist; empty allows any authenticated proxy user.
ADMIN_ALLOWED_GROUPS=
WEB_AUTH_SHARED_SECRET=change-me-web-auth-secret
# Public stats-site base URL used to validate browser return targets.
WEB_AUTH_PUBLIC_BASE_URL=https://stats.example.test
WEB_AUTH_CODE_TTL_SECONDS=300
# Independent private salt for account-link suggestions. Use 32+ random bytes; never share it with clients.
WEB_AUTH_CDKEY_FINGERPRINT_SALT=change-me-to-a-long-random-cdkey-fingerprint-salt
